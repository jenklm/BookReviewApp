<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="92dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="18dp"
            android:paddingTop="28dp"
            android:paddingRight="18dp">

            <!-- 상단 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnBack"
                    android:layout_width="48dp"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:text="‹"
                    android:textColor="#111111"
                    android:textSize="38sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="책 상세보기"
                    android:textColor="#111111"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnTopBookmark"
                    android:layout_width="48dp"
                    android:layout_height="52dp"
                    android:gravity="center"
                    android:text="♡"
                    android:textColor="#111111"
                    android:textSize="28sp" />
            </LinearLayout>

            <!-- 책 기본 정보 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="170dp"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/imgBookCover"
                    android:layout_width="130dp"
                    android:layout_height="160dp"
                    android:background="#D8D8D8"
                    android:scaleType="centerCrop"
                    android:src="@mipmap/ic_launcher" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingLeft="20dp">

                    <TextView
                        android:id="@+id/tvBookTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="달러구트 꿈 백화점"
                        android:textColor="#111111"
                        android:textSize="23sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvBookAuthor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="이미예"
                        android:textColor="#777777"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tvBookMeta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="소설  |  팩토리나인  |  2020.07.08"
                        android:textColor="#777777"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvBookRating"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="★  4.6  (1,234)"
                        android:textColor="#F5B400"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- 탭 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tabIntro"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="소개"
                    android:textColor="#5F35C8"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tabContents"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="목차"
                    android:textColor="#555555"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tabRelated"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="관련 책"
                    android:textColor="#555555"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tabReview"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="리뷰"
                    android:textColor="#555555"
                    android:textSize="16sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E8E8E8" />

            <!-- 소개 문구 -->
            <TextView
                android:id="@+id/tvBookDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:lineSpacingExtra="5dp"
                android:text="잠들어야만 입장 가능한 꿈 백화점에서\n벌어지는 신비롭고 따뜻한 이야기"
                android:textColor="#111111"
                android:textSize="18sp" />

            <!-- 태그 -->
            <TextView
                android:id="@+id/tvBookTags"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:text="#힐링   #판타지   #성장소설"
                android:textColor="#5F35C8"
                android:textSize="14sp" />


            <!-- 관련 영상 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="관련 영상"
                android:textColor="#111111"
                android:textSize="20sp"
                android:textStyle="bold" />

            <FrameLayout
                android:id="@+id/videoBox"
                android:layout_width="match_parent"
                android:layout_height="170dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_video">

                <TextView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_outline_purple"
                    android:gravity="center"
                    android:text="▶"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp" />

                <TextView
                    android:layout_width="110dp"
                    android:layout_height="36dp"
                    android:layout_gravity="bottom|left"
                    android:layout_marginLeft="14dp"
                    android:layout_marginBottom="12dp"
                    android:gravity="center"
                    android:text="예고편  1:32"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
            </FrameLayout>

            <!-- 책 정보 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="26dp"
                android:background="#EEEEEE" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="책 정보"
                android:textColor="#111111"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvBookInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:lineSpacingExtra="8dp"
                android:text="출판사        팩토리나인\n출간일        2020.07.08\n분야           국내도서 > 소설/시/희곡 > 한국소설"
                android:textColor="#666666"
                android:textSize="15sp" />

        </LinearLayout>
    </ScrollView>

    <!-- 하단 버튼 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingLeft="18dp"
        android:paddingRight="18dp">

        <Button
            android:id="@+id/btnBookmark"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/bg_outline_purple"
            android:text="♡  북마크 담기"
            android:textColor="#5F35C8"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnReviewWrite"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginLeft="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_purple"
            android:text="✎  리뷰 작성"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

</FrameLayout>