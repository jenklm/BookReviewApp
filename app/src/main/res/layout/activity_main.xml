<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="76dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="18dp"
            android:paddingTop="34dp"
            android:paddingRight="18dp">

            <!-- 상단 로고 / 알림 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvLogo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Book"
                    android:textColor="#111111"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvBell"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="●"
                    android:textColor="#111111"
                    android:textSize="24sp" />
            </LinearLayout>

            <!-- 검색창 -->
            <EditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_search"
                android:hint="  🔍  책 제목을 검색해주세요."
                android:inputType="text"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:singleLine="true"
                android:textColor="#222222"
                android:textColorHint="#888888"
                android:textSize="14sp" />

            <!-- 추천 책 타이틀 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="28dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="추천 책"
                    android:textColor="#111111"
                    android:textSize="21sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvRecommendMore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="더보기 >"
                    android:textColor="#5F35C8"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- 추천 책 가로 영역 -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/layoutRecommend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- 추천 카드 1 -->
                    <LinearLayout
                        android:id="@+id/cardBook1"
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="12dp"
                        android:background="@drawable/bg_book_card"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="140dp"
                            android:background="#D8D8D8"
                            android:scaleType="centerCrop"
                            android:src="@mipmap/ic_launcher" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingLeft="8dp"
                            android:paddingTop="8dp"
                            android:paddingRight="8dp"
                            android:text="달러구트 꿈 백화점"
                            android:textColor="#111111"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingLeft="8dp"
                            android:paddingTop="3dp"
                            android:text="이미예"
                            android:textColor="#777777"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingLeft="8dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="10dp"
                            android:text="★ 4.6"
                            android:textColor="#F5B400"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- 추천 카드 2 -->
                    <LinearLayout
                        android:id="@+id/cardBook2"
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="12dp"
                        android:background="@drawable/bg_book_card"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="140dp"
                            android:background="#D8D8D8"
                            android:scaleType="centerCrop"
                            android:src="@mipmap/ic_launcher" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingLeft="8dp"
                            android:paddingTop="8dp"
                            android:paddingRight="8dp"
                            android:text="불편한 편의점"
                            android:textColor="#111111"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingLeft="8dp"
                            android:paddingTop="3dp"
                            android:text="김호연"
                            android:textColor="#777777"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingLeft="8dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="10dp"
                            android:text="★ 4.7"
                            android:textColor="#F5B400"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <!-- 추천 카드 3 -->
                    <LinearLayout
                        android:id="@+id/cardBook3"
                        android:layout_width="120dp"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="12dp"
                        android:background="@drawable/bg_book_card"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="140dp"
                            android:background="#D8D8D8"
                            android:scaleType="centerCrop"
                            android:src="@mipmap/ic_launcher" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingLeft="8dp"
                            android:paddingTop="8dp"
                            android:paddingRight="8dp"
                            android:text="아몬드"
                            android:textColor="#111111"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingLeft="8dp"
                            android:paddingTop="3dp"
                            android:text="손원평"
                            android:textColor="#777777"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingLeft="8dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="10dp"
                            android:text="★ 4.5"
                            android:textColor="#F5B400"
                            android:textSize="13sp" />
                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- 카테고리 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="카테고리"
                    android:textColor="#111111"
                    android:textSize="21sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chipAll"
                        android:layout_width="68dp"
                        android:layout_height="38dp"
                        android:layout_marginRight="8dp"
                        android:background="@drawable/bg_chip_selected"
                        android:gravity="center"
                        android:text="전체"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/chipNovel"
                        android:layout_width="68dp"
                        android:layout_height="38dp"
                        android:layout_marginRight="8dp"
                        android:background="@drawable/bg_chip"
                        android:gravity="center"
                        android:text="소설"
                        android:textColor="#5F35C8"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/chipEssay"
                        android:layout_width="68dp"
                        android:layout_height="38dp"
                        android:layout_marginRight="8dp"
                        android:background="@drawable/bg_chip"
                        android:gravity="center"
                        android:text="에세이"
                        android:textColor="#5F35C8"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/chipSelf"
                        android:layout_width="86dp"
                        android:layout_height="38dp"
                        android:layout_marginRight="8dp"
                        android:background="@drawable/bg_chip"
                        android:gravity="center"
                        android:text="자기계발"
                        android:textColor="#5F35C8"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/chipPsychology"
                        android:layout_width="68dp"
                        android:layout_height="38dp"
                        android:layout_marginRight="8dp"
                        android:background="@drawable/bg_chip"
                        android:gravity="center"
                        android:text="심리"
                        android:textColor="#5F35C8"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/chipHuman"
                        android:layout_width="68dp"
                        android:layout_height="38dp"
                        android:layout_marginRight="8dp"
                        android:background="@drawable/bg_chip"
                        android:gravity="center"
                        android:text="인문"
                        android:textColor="#5F35C8"
                        android:textSize="14sp" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- 최근 본 책 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvListTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="최근 본 책"
                    android:textColor="#111111"
                    android:textSize="21sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvRecentMore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="더보기 >"
                    android:textColor="#5F35C8"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- 책 목록 -->
            <LinearLayout
                android:id="@+id/listContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 리스트 1 -->
                <LinearLayout
                    android:id="@+id/rowBook1"
                    android:layout_width="match_parent"
                    android:layout_height="92dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_book_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="72dp"
                        android:background="#D8D8D8"
                        android:scaleType="centerCrop"
                        android:src="@mipmap/ic_launcher" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingLeft="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="달러구트 꿈 백화점"
                            android:textColor="#111111"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="이미예  |  소설"
                            android:textColor="#777777"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="★ 4.6"
                            android:textColor="#F5B400"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="›"
                        android:textColor="#111111"
                        android:textSize="30sp" />
                </LinearLayout>

                <!-- 리스트 2 -->
                <LinearLayout
                    android:id="@+id/rowBook2"
                    android:layout_width="match_parent"
                    android:layout_height="92dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_book_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="72dp"
                        android:background="#D8D8D8"
                        android:scaleType="centerCrop"
                        android:src="@mipmap/ic_launcher" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingLeft="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="데미안"
                            android:textColor="#111111"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="헤르만 헤세  |  소설"
                            android:textColor="#777777"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="★ 4.4"
                            android:textColor="#F5B400"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="›"
                        android:textColor="#111111"
                        android:textSize="30sp" />
                </LinearLayout>

                <!-- 리스트 3 -->
                <LinearLayout
                    android:id="@+id/rowBook3"
                    android:layout_width="match_parent"
                    android:layout_height="92dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_book_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="72dp"
                        android:background="#D8D8D8"
                        android:scaleType="centerCrop"
                        android:src="@mipmap/ic_launcher" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingLeft="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="불편한 편의점"
                            android:textColor="#111111"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="김호연  |  소설"
                            android:textColor="#777777"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="★ 4.7"
                            android:textColor="#F5B400"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="›"
                        android:textColor="#111111"
                        android:textSize="30sp" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- 하단 네비게이션 -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="1000dp"
                android:layout_height="1000dp"
                android:gravity="center"
                android:text="⌂"
                android:textColor="#5F35C8"
                android:textSize="30sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navFocus"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="1000dp"
                android:layout_height="1000dp"
                android:gravity="center"
                android:text="◴"
                android:textColor="#777777"
                android:textSize="45sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/navReview"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="1000dp"
                android:layout_height="1000dp"
                android:gravity="center"
                android:text="✎"
                android:textColor="#777777"
                android:textSize="30sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navMyPage"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="1000dp"
                android:layout_height="1000dp"
                android:gravity="center"
                android:text="♙"
                android:textColor="#777777"
                android:textSize="30sp" />

        </LinearLayout>
    </LinearLayout>

</FrameLayout>
